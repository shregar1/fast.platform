# Flake8 — keep in sync with Ruff (line length 100) and Black (E203).
# Run: flake8 src tests

[flake8]
max-line-length = 100
extend-ignore =
    E203,
    E501,
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    .eggs,
    build,
    dist,
    *.egg-info,
per-file-ignores =
    src/secrets/__init__.py:E402
    tests/integrations/analytics/test_middleware.py:E402
    tests/messaging/notifications/test_retry_policy_webhook_align.py:E402
